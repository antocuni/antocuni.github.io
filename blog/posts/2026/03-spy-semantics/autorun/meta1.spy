@blue
def make_adder(y: dynamic):
    T = type(y)
    def add(x: T) -> T:
        return x + y

    return add

add_world = make_adder(" world")
add5 = make_adder(5)

def main() -> None:
    print(STATIC_TYPE(add_world))
    print(add_world("hello"))
    print("---")
    print(STATIC_TYPE(add5))
    print(add5(2))

